# ═══════════════════════════════════════════════════════════════
# CreepJS Web App - Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ---------------------------------------------------------------------
# Public Environment Variables (exposed to browser)
# ---------------------------------------------------------------------
# These variables are prefixed with NEXT_PUBLIC_ and are embedded in
# the client-side bundle. Do not include sensitive data.
# ---------------------------------------------------------------------

# API Base URL
# - Development: http://localhost:8787 (wrangler dev)
# - Staging: https://api-staging.creepjs.org
# - Production: https://api.creepjs.org
NEXT_PUBLIC_API_URL=http://localhost:8787

# Site URL (used for canonical URLs, sitemaps, and Open Graph)
# - Development: http://localhost:3000
# - Production: https://creepjs.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Web Analytics Token (optional)
# Get from: https://dash.cloudflare.com -> Web Analytics
# This is safe to expose publicly as it's read-only
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Node Environment
# Values: development | production | test
NODE_ENV=development

# ---------------------------------------------------------------------
# Analytics & Monitoring (optional)
# ---------------------------------------------------------------------

# Enable debug mode for analytics events
NEXT_PUBLIC_DEBUG_ANALYTICS=false

# ---------------------------------------------------------------------
# Feature Flags (optional)
# ---------------------------------------------------------------------

# Enable experimental features
NEXT_PUBLIC_ENABLE_EXPERIMENTAL=false

# Enable fingerprint comparison feature
NEXT_PUBLIC_ENABLE_COMPARISON=true

# Enable fingerprint export
NEXT_PUBLIC_ENABLE_EXPORT=true

# ---------------------------------------------------------------------
# Build Configuration (optional)
# ---------------------------------------------------------------------

# Enable bundle analyzer
ANALYZE=false

# Disable telemetry
NEXT_TELEMETRY_DISABLED=1
